{
  "info": {
    "name": "SalonWala Commission Engine",
    "description": "Postman Collection for SalonWala Commission Engine. Contains all endpoints for Rule CRUD, Commission Management, History, Adjustments, and Reporting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Commission Rules",
      "item": [
        {
          "name": "Get All Active Rules",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_ADMIN_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/commissions/rules", "host": ["http://localhost:5000"], "path": ["api", "v1", "commissions", "rules"]}
          }
        },
        {
          "name": "Create Commission Rule",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_ADMIN_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/commissions/rules", "host": ["http://localhost:5000"], "path": ["api", "v1", "commissions", "rules"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ruleName\": \"Standard Haircut\",\n  \"ruleType\": \"PERCENTAGE\",\n  \"targetType\": \"SERVICE\",\n  \"targetId\": \"SERVICE_ID_HERE\",\n  \"rate\": 20,\n  \"priority\": 10\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Commission Management",
      "item": [
        {
          "name": "Get Commissions List",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_ADMIN_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/commissions?status=PENDING", "host": ["http://localhost:5000"], "path": ["api", "v1", "commissions"], "query": [{"key": "status", "value": "PENDING"}]}
          }
        },
        {
          "name": "Get Commission Summary",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_ADMIN_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/commissions/summary", "host": ["http://localhost:5000"], "path": ["api", "v1", "commissions", "summary"]}
          }
        }
      ]
    },
    {
      "name": "Approval Workflow",
      "item": [
        {
          "name": "Bulk Approve Commissions",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_MANAGER_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/commissions/bulk-approve", "host": ["http://localhost:5000"], "path": ["api", "v1", "commissions", "bulk-approve"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": [\"COMMISSION_ID_1\", \"COMMISSION_ID_2\"]\n}"
            }
          }
        },
        {
          "name": "Change Commission Status",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_MANAGER_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/commissions/{{COMMISSION_ID}}/status", "host": ["http://localhost:5000"], "path": ["api", "v1", "commissions", "{{COMMISSION_ID}}", "status"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Commission Adjustments",
      "item": [
        {
          "name": "Add Bonus to Commission",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_MANAGER_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/commissions/{{COMMISSION_ID}}/adjust", "host": ["http://localhost:5000"], "path": ["api", "v1", "commissions", "{{COMMISSION_ID}}", "adjust"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"BONUS\",\n  \"amount\": 50,\n  \"reason\": \"Excellent performance\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Commission History",
      "item": [
        {
          "name": "Get Commission Audit Trail",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_ADMIN_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/commissions/{{COMMISSION_ID}}/history", "host": ["http://localhost:5000"], "path": ["api", "v1", "commissions", "{{COMMISSION_ID}}", "history"]}
          }
        }
      ]
    }
  ]
}
