{
  "info": {
    "name": "SalonWala RBAC Engine",
    "description": "Postman Collection for SalonWala Role & Permission Access Control.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get My Permissions (Frontend Bootstrap)",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN"}],
        "url": {"raw": "http://localhost:5000/api/v1/rbac/me/permissions", "host": ["http://localhost:5000"], "path": ["api", "v1", "rbac", "me", "permissions"]}
      }
    },
    {
      "name": "Assign Role to User",
      "request": {
        "method": "POST",
        "header": [{"key": "Authorization", "value": "Bearer ADMIN_TOKEN"}],
        "url": {"raw": "http://localhost:5000/api/v1/rbac/assign", "host": ["http://localhost:5000"], "path": ["api", "v1", "rbac", "assign"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"USER_ID_HERE\",\n  \"roleId\": \"ROLE_ID_HERE\",\n  \"tenantId\": \"TENANT_ID_HERE\"\n}",
          "options": {"raw": {"language": "json"}}
        }
      }
    }
  ]
}
