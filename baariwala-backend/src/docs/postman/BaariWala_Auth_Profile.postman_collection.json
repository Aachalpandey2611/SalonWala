{
  "info": {
    "name": "SalonWala Auth & Profile Services",
    "description": "Postman Collection for SalonWala Authentication and Identity & Profile Management APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/auth/signup", "host": ["http://localhost:5000"], "path": ["api", "v1", "auth", "signup"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"Customer\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/auth/login", "host": ["http://localhost:5000"], "path": ["api", "v1", "auth", "login"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_ACCESS_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/profiles", "host": ["http://localhost:5000"], "path": ["api", "v1", "profiles"]}
          }
        }
      ]
    }
  ]
}
