{
  "info": {
    "name": "SalonWala Reports Engine",
    "description": "Postman Collection for SalonWala Reports Engine.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Request Report Generation",
      "request": {
        "method": "POST",
        "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN"}],
        "url": {"raw": "http://localhost:5000/api/v1/reports/generate", "host": ["http://localhost:5000"], "path": ["api", "v1", "reports", "generate"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reportCode\": \"FINANCIAL_MONTHLY\",\n  \"format\": \"PDF\",\n  \"parameters\": {\n    \"startDate\": \"2026-06-01T00:00:00Z\",\n    \"endDate\": \"2026-06-30T23:59:59Z\"\n  }\n}",
          "options": {"raw": {"language": "json"}}
        }
      }
    },
    {
      "name": "Check Report Status",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN"}],
        "url": {"raw": "http://localhost:5000/api/v1/reports/:id/status", "host": ["http://localhost:5000"], "path": ["api", "v1", "reports", ":id", "status"]}
      }
    },
    {
      "name": "Download Report",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN"}],
        "url": {"raw": "http://localhost:5000/api/v1/reports/:id/download", "host": ["http://localhost:5000"], "path": ["api", "v1", "reports", ":id", "download"]}
      }
    }
  ]
}
