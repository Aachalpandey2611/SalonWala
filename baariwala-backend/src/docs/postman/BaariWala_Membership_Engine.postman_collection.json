{
  "info": {
    "name": "SalonWala Membership Engine",
    "description": "Postman Collection for SalonWala Membership Engine.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Membership API",
      "item": [
        {
          "name": "Get Available Plans",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "http://localhost:5000/api/v1/memberships/plans", "host": ["http://localhost:5000"], "path": ["api", "v1", "memberships", "plans"]}
          }
        },
        {
          "name": "Get My Active Membership",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_CUSTOMER_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/memberships/my", "host": ["http://localhost:5000"], "path": ["api", "v1", "memberships", "my"]}
          }
        },
        {
          "name": "Purchase Membership",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_CUSTOMER_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/memberships/purchase", "host": ["http://localhost:5000"], "path": ["api", "v1", "memberships", "purchase"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"PLAN_ID_HERE\"\n}"
            }
          }
        },
        {
          "name": "Upgrade Membership",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_CUSTOMER_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/memberships/upgrade", "host": ["http://localhost:5000"], "path": ["api", "v1", "memberships", "upgrade"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPlanId\": \"NEW_PLAN_ID_HERE\"\n}"
            }
          }
        },
        {
          "name": "Cancel Auto-Renew",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_CUSTOMER_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/memberships/cancel", "host": ["http://localhost:5000"], "path": ["api", "v1", "memberships", "cancel"]}
          }
        }
      ]
    }
  ]
}
