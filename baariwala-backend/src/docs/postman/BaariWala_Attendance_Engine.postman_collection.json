            "url": {"raw": "http://localhost:5000/api/v1/attendance/shifts", "host": ["http://localhost:5000"], "path": ["api", "v1", "attendance", "shifts"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Morning Shift\",\n  \"shiftType\": \"MORNING\",\n  \"startTime\": \"09:00\",\n  \"endTime\": \"17:00\"\n}"
            }
          }
        },
        {
          "name": "Assign Shift",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/attendance/shifts/assign", "host": ["http://localhost:5000"], "path": ["api", "v1", "attendance", "shifts", "assign"]},
            "body": {
