              "raw": "{\n  \"leaveType\": \"CASUAL\",\n  \"startDate\": \"2026-06-10\",\n  \"endDate\": \"2026-06-12\",\n  \"totalDays\": 3,\n  \"reason\": \"Family function\"\n}"
