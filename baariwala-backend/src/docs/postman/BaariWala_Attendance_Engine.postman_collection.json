{
  "info": {
    "name": "SalonWala Attendance Engine",
    "description": "Postman Collection for SalonWala Attendance Engine.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Shifts",
      "item": [
        {
          "name": "Create Shift",
          "request": {
