{
  "info": {
    "name": "SalonWala Inventory & Wallet Engine",
    "description": "Postman Collection for Inventory and Wallet Engines.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Inventory API",
      "item": [
        {
          "name": "Get Products",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/inventory/products", "host": ["http://localhost:5000"], "path": ["api", "v1", "inventory", "products"]}
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_ADMIN_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/inventory/products", "host": ["http://localhost:5000"], "path": ["api", "v1", "inventory", "products"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Premium Hair Serum\",\n  \"sku\": \"PHS-100ML-01\",\n  \"category\": \"HAIR_CARE\",\n  \"productType\": \"PROFESSIONAL\",\n  \"brand\": \"L'Oreal\",\n  \"unit\": \"ml\",\n  \"purchasePrice\": 850,\n  \"gstPercent\": 18\n}"
            }
          }
        },
        {
          "name": "Get Inventory",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_SALON_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/inventory?branchId=SALON_ID_HERE", "host": ["http://localhost:5000"], "path": ["api", "v1", "inventory"], "query": [{"key": "branchId", "value": "SALON_ID_HERE"}]}
          }
        },
        {
          "name": "Adjust Stock",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_ADMIN_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/inventory/:inventoryId/adjust", "host": ["http://localhost:5000"], "path": ["api", "v1", "inventory", ":inventoryId", "adjust"]},
            "variable": [{"key": "inventoryId", "value": "INV_ID_HERE"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movementType\": \"PURCHASE\",\n  \"quantity\": 50,\n  \"reason\": \"Received new stock\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Wallet API",
      "item": [
        {
          "name": "Get Wallet",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_CUSTOMER_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/wallet", "host": ["http://localhost:5000"], "path": ["api", "v1", "wallet"]}
          }
        },
        {
          "name": "Get Wallet Transactions",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_CUSTOMER_TOKEN"}],
            "url": {"raw": "http://localhost:5000/api/v1/wallet/transactions", "host": ["http://localhost:5000"], "path": ["api", "v1", "wallet", "transactions"]}
          }
        },
        {
          "name": "Recharge Wallet",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_CUSTOMER_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/wallet/recharge", "host": ["http://localhost:5000"], "path": ["api", "v1", "wallet", "recharge"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1500\n}"
            }
          }
        },
        {
          "name": "Pay Using Wallet",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_CUSTOMER_TOKEN"}, {"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:5000/api/v1/wallet/pay", "host": ["http://localhost:5000"], "path": ["api", "v1", "wallet", "pay"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salonId\": \"SALON_ID_HERE\",\n  \"amount\": 850,\n  \"referenceId\": \"BOOKING_ID_HERE\"\n}"
            }
          }
        }
      ]
    }
  ]
}
